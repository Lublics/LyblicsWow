# ── Server (VPS) ──────────────────────────────────
PORT=3000
API_KEY=change-me-to-a-random-secret-key

# Blizzard API (https://develop.battle.net/access/clients)
BLIZZARD_CLIENT_ID=your_blizzard_client_id
BLIZZARD_CLIENT_SECRET=your_blizzard_client_secret

# ── Agent (PC local) ─────────────────────────────
SERVER_URL=https://your-server-url.com
# API_KEY= (same key as server)
# WOW_PATH=C:/Program Files (x86)/World of Warcraft/_classic_
# WOW_ACCOUNT_PATH=C:/Program Files (x86)/World of Warcraft/_classic_/WTF/Account/YOUR_ACCOUNT_ID/SavedVariables
